generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String
  address   String
  cnic      String   @unique
  isAdmin   Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  properties    Property[]
  ownedRentals  Rental[]   @relation("OwnerRentals")
  tenantRentals Rental[]   @relation("TenantRentals")
  sentListings  Listing[]  @relation("TenantListings")
  complaints    Complaint[] @relation("TenantComplaints")
}

model Property {
  id          String   @id @default(cuid())
  address     String
  city        String
  area        Float
  areaUnit    AreaUnit @default(MARLA)
  rentAmount  Float
  description String   @default("")
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  rentals    Rental[]
  listings   Listing[]
  complaints Complaint[]
  images     PropertyImage[]   // NEW — property ki images
}

// ─────────────────────────────────────────────────────
// NEW: PROPERTY IMAGE
// Server pe upload ki gayi images ka path store hoga.
// ek property ki multiple images ho sakti hain.
// ─────────────────────────────────────────────────────
model PropertyImage {
  id        String   @id @default(cuid())
  url       String   // e.g. /uploads/properties/abc123-front.jpg
  filename  String   // original filename for reference
  isPrimary Boolean  @default(false)  // pehli/main image
  order     Int      @default(0)      // display order
  createdAt DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
}

model Rental {
  id         String   @id @default(cuid())
  startDate  DateTime @default(now())
  rentAmount Float
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  owner    User   @relation("OwnerRentals",  fields: [ownerId],  references: [id])
  ownerId  String

  tenant   User   @relation("TenantRentals", fields: [tenantId], references: [id])
  tenantId String

  payments Payment[]
}

model Payment {
  id        String    @id @default(cuid())
  amount    Float
  month     String
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  rental   Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  rentalId String
}

model Listing {
  id       String        @id @default(cuid())
  status   ListingStatus @default(PENDING)
  isActive Boolean       @default(true)
  message  String        @default("")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  tenant   User   @relation("TenantListings", fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String

  @@unique([propertyId, tenantId])

  agreement Agreement?
}

model Agreement {
  id     String          @id @default(cuid())
  status AgreementStatus @default(DRAFT)

  monthlyRent     Float
  securityDeposit Float
  advanceMonths   Int    @default(1)

  startDate      DateTime
  endDate        DateTime
  durationMonths Int

  noticePeriodDays   Int     @default(30)
  utilitiesIncluded  Boolean @default(false)
  maintenanceByOwner Boolean @default(true)
  petsAllowed        Boolean @default(false)
  additionalTerms    String  @default("")

  tenantSigned   Boolean   @default(false)
  ownerSigned    Boolean   @default(false)
  tenantSignedAt DateTime?
  ownerSignedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String  @unique

  securityPayment SecurityDepositPayment?
}

model SecurityDepositPayment {
  id             String               @id @default(cuid())
  transactionId  String
  amount         Float
  status         DepositPaymentStatus @default(PENDING_VERIFICATION)
  rejectedReason String               @default("")
  submittedAt    DateTime             @default(now())
  verifiedAt     DateTime?

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique
}

model Complaint {
  id          String          @id @default(cuid())
  type        ComplaintType   @default(MAINTENANCE)
  title       String
  description String
  status      ComplaintStatus @default(OPEN)
  adminNote   String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant   User   @relation("TenantComplaints", fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
}

model DissolutionRequest {
  id     String                   @id @default(cuid())
  status DissolutionRequestStatus @default(PENDING)

  // Tenant ki side
  reason             String    // Kyu dissolve karna chahta hai
  proposedVacateDate DateTime? // Tenant ki suggested khali karne ki tarikh
  requestedAt        DateTime  @default(now())

  // Owner ka jawab
  ownerNote    String    @default("")
  respondedAt  DateTime?

  // Relations
  tenant      User      @relation("TenantDissolutions", fields: [tenantId],   references: [id], onDelete: Cascade)
  tenantId    String

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique  // Ek agreement ka ek hi active dissolution request
}




// ─────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────

enum AreaUnit {
  SQFT
  SQM
  MARLA
  KANAL
}

enum ListingStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DepositPaymentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum ComplaintType {
  MAINTENANCE
  COMPLAINT
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DissolutionRequestStatus {
  PENDING   // Tenant ne request ki, owner ka intezaar
  ACCEPTED  // Owner ne maan liya → agreement CANCELLED
  DECLINED  // Owner ne mana kiya, agreement chalti rahe
}

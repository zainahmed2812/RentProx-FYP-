generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String
  address   String
  cnic      String   @unique
  isAdmin   Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  properties    Property[]
  sentListings  Listing[]  @relation("TenantListings")
  ownedRentals  Rental[]   @relation("OwnerRentals")
  tenantRentals Rental[]   @relation("TenantRentals")

  dissolutionRequests DissolutionRequest[] @relation("TenantDissolutions")
}

// ─────────────────────────────────────────────────────
model Property {
  id          String   @id @default(cuid())
  address     String
  city        String
  area        Float
  areaUnit    AreaUnit @default(MARLA)
  rentAmount  Float
  description String   @default("")
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  listings Listing[]
  rentals  Rental[]
}

// ─────────────────────────────────────────────────────
model Listing {
  id        String        @id @default(cuid())
  status    ListingStatus @default(PENDING)
  message   String        @default("")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  tenant   User   @relation("TenantListings", fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String

  @@unique([propertyId, tenantId])

  agreement Agreement?
}

// ─────────────────────────────────────────────────────
//  RENTAL — Agreement active hone par create hota hai
// ─────────────────────────────────────────────────────
model Rental {
  id         String   @id @default(cuid())
  startDate  DateTime @default(now())
  endDate    DateTime?
  rentAmount Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  owner    User   @relation("OwnerRentals",  fields: [ownerId],  references: [id])
  ownerId  String

  tenant   User   @relation("TenantRentals", fields: [tenantId], references: [id])
  tenantId String

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique
}

// ─────────────────────────────────────────────────────
model Agreement {
  id     String          @id @default(cuid())
  status AgreementStatus @default(DRAFT)

  monthlyRent     Float
  securityDeposit Float
  advanceMonths   Int    @default(1)

  startDate      DateTime
  endDate        DateTime
  durationMonths Int

  noticePeriodDays   Int     @default(30)
  utilitiesIncluded  Boolean @default(false)
  maintenanceByOwner Boolean @default(true)
  petsAllowed        Boolean @default(false)
  additionalTerms    String  @default("")

  tenantSigned   Boolean   @default(false)
  ownerSigned    Boolean   @default(false)
  tenantSignedAt DateTime?
  ownerSignedAt  DateTime?

  // dissolution audit
  dissolvedAt     DateTime?
  dissolvedBy     String    @default("")
  dissolutionNote String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String  @unique

  rental             Rental?
  dissolutionRequest DissolutionRequest?
  securityPayment    SecurityDepositPayment?
  monthlyPayments    MonthlyRentPayment[]
  utilityBills       UtilityBill[]
}

// ─────────────────────────────────────────────────────
model SecurityDepositPayment {
  id             String                       @id @default(cuid())
  transactionId  String
  amount         Float
  status         SecurityDepositPaymentStatus @default(PENDING_VERIFICATION)
  rejectedReason String                       @default("")
  submittedAt    DateTime                     @default(now())
  verifiedAt     DateTime?

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique
}

// ─────────────────────────────────────────────────────
model MonthlyRentPayment {
  id             String                   @id @default(cuid())
  month          String                   // "2026-04" format
  transactionId  String
  amount         Float
  status         MonthlyRentPaymentStatus @default(PENDING_VERIFICATION)
  rejectedReason String                   @default("")
  submittedAt    DateTime                 @default(now())
  verifiedAt     DateTime?

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String

  @@unique([agreementId, month])
}

// ─────────────────────────────────────────────────────
model DissolutionRequest {
  id     String                   @id @default(cuid())
  status DissolutionRequestStatus @default(PENDING)

  reason             String
  proposedVacateDate DateTime?
  requestedAt        DateTime  @default(now())

  ownerNote   String    @default("")
  respondedAt DateTime?

  tenant      User      @relation("TenantDissolutions", fields: [tenantId],   references: [id], onDelete: Cascade)
  tenantId    String

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique
}


// ─────────────────────────────────────────────────────
//  UTILITY BILL
// ─────────────────────────────────────────────────────
model UtilityBill {
  id          String   @id @default(cuid())
  month       String   // "2026-04" format
  imagePath   String   // server pr path e.g. /uploads/bills/xyz.jpg
  billType    String   @default("Utility") // Electricity, Gas, Water, etc
  notes       String   @default("")
  uploadedAt  DateTime @default(now())

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String
}

// ─────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────
enum AreaUnit {
  SQFT
  SQM
  MARLA
  KANAL
}

enum ListingStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DissolutionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MonthlyRentPaymentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum SecurityDepositPaymentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

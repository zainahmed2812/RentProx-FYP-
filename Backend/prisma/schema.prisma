generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String
  address   String
  cnic      String   @unique
  isAdmin   Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  properties    Property[]
  ownedRentals  Rental[]   @relation("OwnerRentals")
  tenantRentals Rental[]   @relation("TenantRentals")
  sentListings  Listing[]  @relation("TenantListings")

  // NEW
  dissolutionRequests DissolutionRequest[] @relation("TenantDissolutions")
}

model Property {
  id          String   @id @default(cuid())
  address     String
  city        String
  area        Float
  areaUnit    AreaUnit @default(MARLA)
  rentAmount  Float
  description String   @default("")
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  rentals  Rental[]
  listings Listing[]
}

model Rental {
  id         String   @id @default(cuid())
  startDate  DateTime @default(now())
  rentAmount Float
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  owner    User   @relation("OwnerRentals",  fields: [ownerId],  references: [id])
  ownerId  String

  tenant   User   @relation("TenantRentals", fields: [tenantId], references: [id])
  tenantId String

  payments Payment[]
}

model Payment {
  id        String    @id @default(cuid())
  amount    Float
  month     String
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  rental   Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  rentalId String
}

model Listing {
  id        String        @id @default(cuid())
  status    ListingStatus @default(PENDING)
  message   String        @default("")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  tenant   User   @relation("TenantListings", fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String

  @@unique([propertyId, tenantId])

  agreement Agreement?
}

model Agreement {
  id     String          @id @default(cuid())
  status AgreementStatus @default(DRAFT)

  monthlyRent     Float
  securityDeposit Float
  advanceMonths   Int    @default(1)

  startDate      DateTime
  endDate        DateTime
  durationMonths Int

  noticePeriodDays   Int     @default(30)
  utilitiesIncluded  Boolean @default(false)
  maintenanceByOwner Boolean @default(true)
  petsAllowed        Boolean @default(false)
  additionalTerms    String  @default("")

  tenantSigned   Boolean   @default(false)
  ownerSigned    Boolean   @default(false)
  tenantSignedAt DateTime?
  ownerSignedAt  DateTime?

  // NEW: dissolution audit
  dissolvedAt     DateTime?
  dissolvedBy     String    @default("")
  dissolutionNote String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String  @unique

  // NEW: back-relation
  dissolutionRequest DissolutionRequest?
}

// ─────────────────────────────────────────────────────
//  NEW MODEL: DISSOLUTION REQUEST
// ─────────────────────────────────────────────────────

model DissolutionRequest {
  id     String                   @id @default(cuid())
  status DissolutionRequestStatus @default(PENDING)

  reason             String
  proposedVacateDate DateTime?
  requestedAt        DateTime  @default(now())

  ownerNote   String    @default("")
  respondedAt DateTime?

  tenant      User      @relation("TenantDissolutions", fields: [tenantId],   references: [id], onDelete: Cascade)
  tenantId    String

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementId String    @unique
}

// ─────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────

enum AreaUnit {
  SQFT
  SQM
  MARLA
  KANAL
}

enum ListingStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

// NEW
enum DissolutionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}
